---
import '../styles/blog.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = image || '/assets/img/og-cover.png';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07111f" />

    <!-- SEO -->
    <title>{title} | Cards Trading Blog</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Cards Trading" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@CardsTradingCom" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- Favicon (cache-busted via ?v=2 pour forcer refresh des navigateurs) -->
    <link rel="icon" type="image/png" href="/assets/img/logo.png?v=2" />
    <link rel="shortcut icon" type="image/png" href="/assets/img/logo.png?v=2" />
    <link rel="apple-touch-icon" href="/assets/img/logo.png?v=2" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Header -->
    <header class="blog-header">
      <a href="/" class="blog-header-logo" aria-label="Accueil Cards Trading">
        <img src="/assets/img/logo.png" alt="Cards Trading" />
      </a>
      <nav class="blog-header-nav">
        <a href="/blog" class="active">Blog</a>
        <a href="/#avantages">Avantages</a>
        <a href="/#features">Fonctionnalit&eacute;s</a>
        <a href="/">Accueil</a>
      </nav>
    </header>

    <!-- Contenu -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="blog-footer">
      <p>&copy; {new Date().getFullYear()} Cards-Trading.com &mdash; La marketplace TCG</p>
      <p style="margin-top: 8px;">
        <a href="/">Accueil</a> &middot;
        <a href="/blog">Blog</a> &middot;
        <a href="/cgu.html">CGU</a> &middot;
        <a href="/mentions-legales.html">Mentions l&eacute;gales</a>
      </p>
    </footer>
  </body>
</html>
